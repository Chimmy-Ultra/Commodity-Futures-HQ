PORT=3000
# DATABENTO_API_KEY=your_databento_api_key_here

# ── Claude Backend Mode ──────────────────────────────────────────
# cli  (default) — uses local claude.exe with Claude Max subscription (no API key needed)
# api            — uses Anthropic API key (required for deployment on other machines)
CLAUDE_MODE=cli

# Required only when CLAUDE_MODE=api
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
